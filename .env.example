# O.L.I.V.I.A. Configuration Example
# Copy this file to .env and fill in your values

# Hugging Face (for model downloads)
HUGGING_FACE_TOKEN=hf_your_token_here

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=olivia-finetuned

# Ollama Performance Tuning (set these as system environment variables)
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=24h
OLLAMA_FLASH_ATTENTION=1

# STT Configuration
STT_MODEL_SIZE=small.en
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16

# TTS Configuration
TTS_DEVICE=cuda
TTS_VOICE_REFERENCE=assets/voice/reference.wav
TTS_CFG_WEIGHT=0.5
TTS_EXAGGERATION=0.5

# TTS Optimization (Phase 2: PyTorch Acceleration)
# Recommended for high-end GPU (RTX 4080+, 16GB+ VRAM)
TTS_USE_TORCH_COMPILE=true
TTS_COMPILE_MODE=reduce-overhead        # Options: default, reduce-overhead, max-autotune
TTS_ENABLE_INFERENCE_MODE=true
TTS_ENABLE_CUDNN_BENCHMARK=true
TTS_ENABLE_TF32=true                    # Ampere+ GPUs only (RTX 30xx/40xx)

# TTS Latency Optimization (Phase 4: <200ms TTFB target)
TTS_ADAPTIVE_CHUNKING=true
TTS_FIRST_CHUNK_TOKENS=30               # Smaller first chunk for faster TTFB
TTS_SUBSEQUENT_CHUNK_TOKENS=50          # Standard chunks for quality

# TTS Performance Monitoring (Phase 5)
TTS_ENABLE_METRICS=true
TTS_LOG_METRICS=false                   # Set true for debugging
TTS_MEMORY_CLEANUP_INTERVAL=10          # Clean CUDA memory every N generations

# Memory
MEMORY_PERSIST_DIR=data/memory_db

# Logging
LOG_LEVEL=INFO

# API Server (localhost-only by default; widen deliberately if serving the LAN)
HOST=127.0.0.1
PORT=8000
